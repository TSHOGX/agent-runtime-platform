#!/usr/bin/env python3
import argparse
import json
import os
import subprocess
import sys
import threading
import time
import urllib.error
import urllib.request
import uuid
from pathlib import Path


INBOX = "inbox"
OUTBOX = "outbox"
HEARTBEAT = "heartbeat"
HOST_HEARTBEAT_DIR = "host-heartbeat"
TMP = "tmp"
BRIDGE_HEARTBEAT = "bridge"
HOST_HEARTBEAT = "host"
CHECKPOINT_READY = "checkpoint-ready"
HOST_ONLY_DUMMY_API_KEY = "harness-model-proxy-dummy-key"
CLAUDE_MARKER_DIR = ".harness"
CLAUDE_SESSION_MARKER = "claude-session-initialized.json"
PI_CODING_AGENT_DIR = "/agent-home/.pi/agent"
PI_SESSION_DIR = "/agent-home/.pi/agent/sessions"
PI_MODELS_SANDBOX_PATH = "/agent-home/.pi/agent/models.json"
PI_SETTINGS_SANDBOX_PATH = "/agent-home/.pi/agent/settings.json"
PI_HARNESS_PROXY_PROVIDER = "harness_anthropic_proxy"
DRIVER_STATE_DIGEST_PREFIX = b"driver_state_digest_v1\n"


def seq_name(seq):
    return f"{seq:020d}.json"


def parse_seq_name(name):
    if len(name) != len("00000000000000000001.json") or not name.endswith(".json"):
        return None
    raw = name[:-5]
    if not raw.isdigit():
        return None
    seq = int(raw, 10)
    if seq <= 0 or seq_name(seq) != name:
        return None
    return seq


def fsync_dir(path):
    fd = os.open(path, os.O_RDONLY | getattr(os, "O_DIRECTORY", 0))
    try:
        os.fsync(fd)
    finally:
        os.close(fd)


def write_heartbeat(root, name):
    if name not in {BRIDGE_HEARTBEAT, HOST_HEARTBEAT}:
        raise ValueError(f"unsupported heartbeat file {name}")
    dirname = HOST_HEARTBEAT_DIR if name == HOST_HEARTBEAT else HEARTBEAT
    write_control_file(root, dirname, name, ".heartbeat")


def write_checkpoint_ready(root):
    write_control_file(root, HEARTBEAT, CHECKPOINT_READY, ".ready")


def clear_checkpoint_ready(root):
    ready = Path(root) / HEARTBEAT / CHECKPOINT_READY
    try:
        ready.unlink()
        fsync_dir(ready.parent)
    except FileNotFoundError:
        pass


def write_control_file(root, dirname, name, suffix):
    root = Path(root)
    tmp = root / TMP
    target_dir = root / dirname
    tmp.mkdir(parents=True, exist_ok=True)
    target_dir.mkdir(parents=True, exist_ok=True)
    tmp_path = tmp / f"{uuid.uuid4()}{suffix}"
    with open(tmp_path, "xb") as f:
        f.write(f"{time.time_ns()}\n".encode("ascii"))
        f.flush()
        os.fsync(f.fileno())
    try:
        os.replace(tmp_path, target_dir / name)
        fsync_dir(target_dir)
    finally:
        try:
            tmp_path.unlink()
        except FileNotFoundError:
            pass


def claude_session_marker_path(agent_home):
    return Path(agent_home) / CLAUDE_MARKER_DIR / CLAUDE_SESSION_MARKER


def claude_session_marker_matches(agent_home, session_uuid):
    marker = claude_session_marker_path(agent_home)
    try:
        raw = marker.read_text(encoding="utf-8").strip()
    except OSError:
        return False
    if raw == session_uuid:
        return True
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        return False
    return payload.get("claude_session_uuid") == session_uuid


def claude_session_state_exists(agent_home, session_uuid):
    projects = Path(agent_home) / ".claude" / "projects"
    if not projects.is_dir():
        return False
    try:
        for path in projects.glob(f"**/{session_uuid}.jsonl"):
            if path.is_file() and path.stat().st_size > 0:
                return True
    except OSError:
        return False
    return False


def claude_session_initialized(agent_home, session_uuid):
    return claude_session_marker_matches(agent_home, session_uuid) or claude_session_state_exists(
        agent_home,
        session_uuid,
    )


def mark_claude_session_initialized(agent_home, session_uuid):
    marker = claude_session_marker_path(agent_home)
    marker_dir = marker.parent
    marker_dir.mkdir(parents=True, exist_ok=True)
    tmp_path = marker_dir / f".{uuid.uuid4()}.tmp"
    payload = {
        "claude_session_uuid": session_uuid,
        "marked_at_ns": time.time_ns(),
    }
    data = (json.dumps(payload, sort_keys=True, separators=(",", ":")) + "\n").encode("utf-8")
    with open(tmp_path, "xb") as f:
        f.write(data)
        f.flush()
        os.fsync(f.fileno())
    try:
        os.replace(tmp_path, marker)
        fsync_dir(marker_dir)
    finally:
        try:
            tmp_path.unlink()
        except FileNotFoundError:
            pass


def try_mark_claude_session_initialized(agent_home, session_uuid):
    try:
        mark_claude_session_initialized(agent_home, session_uuid)
    except OSError:
        pass


def payload_mentions_claude_session(payload, session_uuid):
    return payload.get("session_id") == session_uuid or payload.get("sessionId") == session_uuid


def canonical_json_bytes(payload):
    return json.dumps(payload, ensure_ascii=False, sort_keys=True, separators=(",", ":")).encode("utf-8")


def driver_state_digest(payload):
    import hashlib

    return "sha256:" + hashlib.sha256(DRIVER_STATE_DIGEST_PREFIX + canonical_json_bytes(payload)).hexdigest()


class Queue:
    def __init__(self, root, name):
        self.root = Path(root)
        self.name = name
        self.dir = self.root / name
        self.tmp = self.root / TMP
        self.tmp.mkdir(parents=True, exist_ok=True)
        self.dir.mkdir(parents=True, exist_ok=True)

    def next_seq(self):
        max_seq = 0
        for entry in self.dir.iterdir():
            seq = parse_seq_name(entry.name)
            if seq is not None and seq > max_seq:
                max_seq = seq
        return max_seq + 1

    def write(self, envelope):
        envelope = dict(envelope)
        envelope.setdefault("message_id", str(uuid.uuid4()))
        payload = (json.dumps(envelope, ensure_ascii=False, sort_keys=True, separators=(",", ":")) + "\n").encode("utf-8")
        tmp_path = self.tmp / f"{uuid.uuid4()}.json"
        with open(tmp_path, "xb") as f:
            f.write(payload)
            f.flush()
            os.fsync(f.fileno())
        try:
            while True:
                target = self.dir / seq_name(self.next_seq())
                try:
                    os.link(tmp_path, target)
                    fsync_dir(self.dir)
                    return envelope["message_id"]
                except FileExistsError:
                    continue
        finally:
            try:
                tmp_path.unlink()
            except FileNotFoundError:
                pass

    def read_all(self):
        files = []
        for entry in self.dir.iterdir():
            seq = parse_seq_name(entry.name)
            if seq is None:
                continue
            with open(entry, "r", encoding="utf-8") as f:
                files.append((seq, entry, json.load(f)))
        return sorted(files, key=lambda item: item[0])

    def unlink(self, path):
        try:
            Path(path).unlink()
            fsync_dir(self.dir)
        except (FileNotFoundError, PermissionError):
            pass


def canonical_driver_id(value):
    value = (value or "").strip()
    if value == "claude":
        return "claude_code"
    return value or "claude_code"


def args_driver_id(args):
    return canonical_driver_id(getattr(args, "driver_id", getattr(args, "agent", "claude_code")))


class BridgeClient:
    def __init__(self, root, session_id, generation_id, driver_id, poll_interval=0.05):
        self.root = Path(root)
        self.session_id = session_id
        self.generation_id = generation_id
        self.driver_id = canonical_driver_id(driver_id)
        self.poll_interval = poll_interval
        self.inbox = Queue(root, INBOX)
        self.outbox = Queue(root, OUTBOX)
        self.last_output_sequence_by_turn = {}
        self.leased_turn_id = None

    def envelope(self, message_type, request_id=None, turn_id=None, payload=None):
        envelope = {
            "message_id": str(uuid.uuid4()),
            "request_id": request_id or str(uuid.uuid4()),
            "type": message_type,
            "session_id": self.session_id,
            "generation_id": self.generation_id,
        }
        if turn_id is not None:
            envelope["turn_id"] = turn_id
        if payload is not None:
            envelope["payload"] = payload
        return envelope

    def send(self, message_type, request_id=None, turn_id=None, payload=None):
        envelope = self.envelope(message_type, request_id=request_id, turn_id=turn_id, payload=payload)
        self.outbox.write(envelope)
        return envelope

    def wait_response(self, request_id, timeout=None):
        deadline = None if timeout is None else time.monotonic() + timeout
        while True:
            for _, path, envelope in self.inbox.read_all():
                if envelope.get("request_id") != request_id:
                    continue
                self.inbox.unlink(path)
                if envelope.get("type") == "error":
                    payload = envelope.get("payload") or {}
                    raise RuntimeError(payload.get("error") or "bridge error")
                return envelope
            if deadline is not None and time.monotonic() >= deadline:
                raise TimeoutError(f"timed out waiting for {request_id}")
            time.sleep(self.poll_interval)

    def hello(self, timeout=None):
        request_id = str(uuid.uuid4())
        self.send(
            "hello",
            request_id=request_id,
            payload={"driver_id": self.driver_id, "protocol_version": 2, "turn_input_schema": "RunTurn"},
        )
        response = self.wait_response(request_id, timeout=timeout)
        payload = response.get("payload") or {}
        self.last_output_sequence_by_turn = {
            int(turn_id): int(sequence)
            for turn_id, sequence in (payload.get("last_output_sequence_by_turn") or {}).items()
        }
        self.leased_turn_id = payload.get("leased_turn_id")
        return payload

    def probe_network(self, timeout=None):
        request_id = str(uuid.uuid4())
        self.send("probe_network", request_id=request_id)
        return self.wait_response(request_id, timeout=timeout).get("payload") or {}

    def heartbeat(self):
        self.touch_bridge_heartbeat()
        self.send("heartbeat")

    def touch_bridge_heartbeat(self):
        write_heartbeat(self.root, BRIDGE_HEARTBEAT)

    def mark_checkpoint_ready(self):
        write_checkpoint_ready(self.root)

    def clear_checkpoint_ready(self):
        clear_checkpoint_ready(self.root)

    def claim_next_turn(self, timeout=None):
        request_id = str(uuid.uuid4())
        self.send("claim_next_turn", request_id=request_id)
        response = self.wait_response(request_id, timeout=timeout)
        if response.get("type") != "grant":
            return None
        return response.get("payload") or {}

    def resume_turn(self, turn_id, timeout=None):
        request_id = str(uuid.uuid4())
        self.send("resume_turn", request_id=request_id, turn_id=turn_id)
        response = self.wait_response(request_id, timeout=timeout)
        if response.get("type") != "grant":
            return None
        return response.get("payload") or {}

    def ack_turn_started(self, turn_id, sandbox_source_ip):
        self.send("ack_turn_started", turn_id=turn_id, payload={"sandbox_source_ip": sandbox_source_ip})

    def emit_output(self, turn_id, output_sequence, payload, stream="stdout"):
        self.send(
            "emit_output",
            turn_id=turn_id,
            payload={"output_sequence": output_sequence, "stream": stream, "payload": payload},
        )

    def ack_turn_completed(self, turn_id, status="completed", error_class="", error="", driver_state_update=None):
        payload = {"status": status}
        if error_class:
            payload["error_class"] = error_class
        if error:
            payload["error"] = error
        if driver_state_update is not None:
            payload["driver_state_update"] = driver_state_update
        self.send("ack_turn_completed", turn_id=turn_id, payload=payload)


class ShellTurnRunner:
    def __init__(self):
        self.proc = None

    def _start(self):
        if self.proc is not None and self.proc.poll() is None:
            return
        self.proc = subprocess.Popen(
            ["/usr/local/bin/harness-shell-agent"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
        )

    def run_turn(self, content, emit):
        self._start()
        frame = json.dumps({"type": "turn", "content": content}, ensure_ascii=False, separators=(",", ":"))
        self.proc.stdin.write(frame + "\n")
        self.proc.stdin.flush()
        while True:
            line = self.proc.stdout.readline()
            if line == "":
                raise RuntimeError("shell agent exited before turn completed")
            stripped = line.rstrip("\n")
            try:
                payload = json.loads(stripped)
            except json.JSONDecodeError:
                emit("stdout", stripped)
                continue
            if payload.get("type") == "harness.turn_done":
                return "completed", "", ""
            emit("stdout", stripped)

    def close(self):
        if self.proc is None:
            return
        try:
            self.proc.terminate()
        except OSError:
            pass


class ClaudeTurnRunner:
    def __init__(self):
        self.first_turn = True

    def run_turn(self, content, emit):
        session_uuid = os.environ.get("CLAUDE_SESSION_UUID", "")
        if not session_uuid:
            raise RuntimeError("CLAUDE_SESSION_UUID is required for claude agent")
        agent_home = os.environ.get("HARNESS_AGENT_HOME", "")
        if not agent_home:
            raise RuntimeError("HARNESS_AGENT_HOME is required for claude agent")
        claude_command = [
            "/usr/local/bin/claude",
            "--bare",
            "--permission-mode",
            "bypassPermissions",
            "-p",
            "--model",
            os.environ.get("CLAUDE_MODEL", "sonnet"),
            "--input-format",
            "stream-json",
            "--output-format",
            os.environ.get("CLAUDE_OUTPUT_FORMAT", "stream-json"),
            "--include-partial-messages",
            "--replay-user-messages",
            "--verbose",
        ]
        resume_claude = (
            os.environ.get("CLAUDE_RESUME", "0") == "1"
            or not self.first_turn
            or claude_session_initialized(agent_home, session_uuid)
        )
        if resume_claude:
            claude_command.extend(["--resume", session_uuid])
        else:
            claude_command.extend(["--session-id", session_uuid])
        self.first_turn = False

        env = {
            "PATH": os.environ.get("PATH", "/usr/local/bin:/usr/bin:/bin"),
            "HOME": agent_home,
            "USER": "harness",
            "LOGNAME": "harness",
            "HARNESS_AGENT_HOME": agent_home,
            "ANTHROPIC_BASE_URL": os.environ.get("ANTHROPIC_BASE_URL", ""),
            "ANTHROPIC_API_KEY": HOST_ONLY_DUMMY_API_KEY,
        }
        for optional_name in ("CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC", "LANG", "TMPDIR"):
            optional_value = os.environ.get(optional_name)
            if optional_value:
                env[optional_name] = optional_value
        target_uid = os.environ.get("HARNESS_AGENT_UID", "65534")
        target_gid = os.environ.get("HARNESS_AGENT_GID", "65534")
        if str(os.geteuid()) == target_uid and str(os.getegid()) == target_gid:
            command = claude_command
        else:
            command = [
                "setpriv",
                "--reuid",
                target_uid,
                "--regid",
                target_gid,
                "--clear-groups",
                "env",
                f"HOME={agent_home}",
                "USER=harness",
                "LOGNAME=harness",
                *claude_command,
            ]
        frame = json.dumps(
            {"type": "user", "message": {"role": "user", "content": [{"type": "text", "text": content}]}},
            ensure_ascii=False,
            separators=(",", ":"),
        )
        proc = subprocess.Popen(
            command,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            env=env,
        )
        proc.stdin.write(frame + "\n")
        proc.stdin.close()
        status = "completed"
        error_class = ""
        error = ""
        saw_session = False
        for line in proc.stdout:
            stripped = line.rstrip("\n")
            if stripped:
                emit("stdout", stripped)
                try:
                    payload = json.loads(stripped)
                except json.JSONDecodeError:
                    continue
                if payload_mentions_claude_session(payload, session_uuid):
                    saw_session = True
                if payload.get("type") == "error":
                    status = "failed"
                    error_class = "agent_execution_failed"
                    error = payload.get("message") or payload.get("error") or "claude stream error"
        rc = proc.wait()
        if rc != 0 and status == "completed":
            status = "failed"
            error_class = "agent_exit_nonzero"
            error = f"claude exited with status {rc}"
        if saw_session or claude_session_state_exists(agent_home, session_uuid):
            try_mark_claude_session_initialized(agent_home, session_uuid)
        return status, error_class, error

    def close(self):
        pass


def validate_pi_runtime_environment():
    required = {
        "PI_CODING_AGENT_DIR": PI_CODING_AGENT_DIR,
        "PI_CODING_AGENT_SESSION_DIR": PI_SESSION_DIR,
        "PI_OFFLINE": "1",
        "PI_SKIP_VERSION_CHECK": "1",
        "PI_TELEMETRY": "0",
    }
    for name, want in required.items():
        got = os.environ.get(name, "")
        if got != want:
            raise RuntimeError(f"{name} must be {want}")


def validate_pi_config_materialization():
    for path in (PI_MODELS_SANDBOX_PATH, PI_SETTINGS_SANDBOX_PATH):
        candidate = Path(path)
        if candidate.is_symlink():
            raise RuntimeError(f"pi config must not be a sandbox symlink: {path}")
        try:
            st = candidate.stat()
        except OSError as err:
            raise RuntimeError(f"pi config missing: {path}") from err
        if not candidate.is_file():
            raise RuntimeError(f"pi config is not a regular file: {path}")
        if pi_config_writable_by_sandbox_uid(st):
            raise RuntimeError(f"pi config is writable by sandbox uid/gid: {path}")
        with open(candidate, "rb") as f:
            f.read(1)


def pi_config_writable_by_sandbox_uid(st):
    try:
        uid = int(os.environ.get("HARNESS_AGENT_UID", "65534"))
        gid = int(os.environ.get("HARNESS_AGENT_GID", "65534"))
    except ValueError:
        uid, gid = 65534, 65534
    mode = st.st_mode
    return bool(
        mode & 0o002
        or (st.st_uid == uid and mode & 0o200)
        or (st.st_gid == gid and mode & 0o020)
    )


def normalize_pi_session_file(session_file):
    raw = str(session_file or "").strip()
    if not raw:
        raise RuntimeError("pi sessionFile is required")
    if "\\" in raw:
        raise RuntimeError("pi sessionFile must use POSIX separators")
    root = Path(PI_SESSION_DIR)
    candidate = Path(raw)
    if not candidate.is_absolute():
        candidate = root / candidate
    try:
        real_root = root.resolve(strict=True)
        real_candidate = candidate.resolve(strict=True)
    except OSError as err:
        raise RuntimeError(f"pi sessionFile realpath failed: {raw}") from err
    try:
        rel = real_candidate.relative_to(real_root)
    except ValueError as err:
        raise RuntimeError(f"pi sessionFile escapes session dir: {raw}") from err
    if str(rel) in {"", "."} or any(part in {"", ".", ".."} for part in rel.parts):
        raise RuntimeError(f"pi sessionFile has invalid relative path: {raw}")
    relpath = rel.as_posix()
    return relpath, str(root / relpath)


class PiRPCTurnRunner:
    def __init__(self):
        self.proc = None
        self.current_grant = {}
        self.restored_state_digest = ""

    def set_turn_context(self, grant):
        self.current_grant = dict(grant or {})

    def _start(self):
        validate_pi_runtime_environment()
        validate_pi_config_materialization()
        if self.proc is not None and self.proc.poll() is None:
            return
        model = os.environ.get("PI_MODEL") or os.environ.get("CLAUDE_MODEL") or "sonnet"
        pi_command = [
            os.environ.get("PI_BIN", "/usr/local/bin/pi"),
            "--mode",
            "rpc",
            "--provider",
            PI_HARNESS_PROXY_PROVIDER,
            "--model",
            model,
            "--session-dir",
            PI_SESSION_DIR,
        ]
        env = {
            "PATH": os.environ.get("PATH", "/usr/local/bin:/usr/bin:/bin"),
            "HOME": "/agent-home",
            "USER": "harness",
            "LOGNAME": "harness",
            "PI_CODING_AGENT_DIR": PI_CODING_AGENT_DIR,
            "PI_CODING_AGENT_SESSION_DIR": PI_SESSION_DIR,
            "PI_OFFLINE": "1",
            "PI_SKIP_VERSION_CHECK": "1",
            "PI_TELEMETRY": "0",
            "ANTHROPIC_BASE_URL": os.environ.get("ANTHROPIC_BASE_URL", ""),
        }
        for optional_name in ("LANG", "TMPDIR"):
            optional_value = os.environ.get(optional_name)
            if optional_value:
                env[optional_name] = optional_value
        target_uid = os.environ.get("HARNESS_AGENT_UID", "65534")
        target_gid = os.environ.get("HARNESS_AGENT_GID", "65534")
        if str(os.geteuid()) == target_uid and str(os.getegid()) == target_gid:
            command = pi_command
        else:
            command = [
                "setpriv",
                "--reuid",
                target_uid,
                "--regid",
                target_gid,
                "--clear-groups",
                "env",
                "HOME=/agent-home",
                "USER=harness",
                "LOGNAME=harness",
                *[f"{name}={value}" for name, value in env.items() if name.startswith("PI_")],
                *pi_command,
            ]
        self.proc = subprocess.Popen(
            command,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            env=env,
        )

    def _write_rpc(self, payload):
        self.proc.stdin.write(json.dumps(payload, ensure_ascii=False, separators=(",", ":")) + "\n")
        self.proc.stdin.flush()

    def _read_rpc(self):
        line = self.proc.stdout.readline()
        if line == "":
            rc = self.proc.poll()
            detail = "exited" if rc is None else f"exited with status {rc}"
            raise RuntimeError(f"pi rpc process {detail}")
        stripped = line.rstrip("\n")
        try:
            payload = json.loads(stripped)
        except json.JSONDecodeError as err:
            raise RuntimeError(f"pi rpc emitted non-json output: {stripped}") from err
        return stripped, payload

    def _request_response(self, payload):
        self._write_rpc(payload)
        request_id = payload.get("id")
        command = payload.get("type")
        while True:
            _, event = self._read_rpc()
            if event.get("type") == "response" and event.get("id") == request_id:
                if not event.get("success", False):
                    raise RuntimeError(f"pi rpc command {command} failed")
                return event
            if event.get("type") == "error":
                raise RuntimeError("pi rpc error during internal command")

    def run_turn(self, content, emit):
        validate_pi_config_materialization()
        self._start()
        turn_id = int(self.current_grant.get("turn_id") or 0)
        self._restore_session_if_needed(turn_id)
        prompt_id = f"harness-turn-{turn_id or int(time.time_ns())}"
        self._write_rpc({"id": prompt_id, "type": "prompt", "message": content})
        status = "completed"
        error_class = ""
        error = ""
        while True:
            stripped, event = self._read_rpc()
            emit("stdout", stripped)
            event_type = event.get("type")
            if event_type == "response" and event.get("id") == prompt_id and not event.get("success", False):
                status = "failed"
                error_class = "agent_prompt_rejected"
                error = f"pi prompt rejected: {event.get('error') or event.get('message') or 'unknown error'}"
                break
            if event_type == "error":
                status = "failed"
                error_class = "agent_execution_failed"
                error = event.get("message") or event.get("error") or "pi rpc error"
                break
            if event_type in {"turn_end", "agent_end"}:
                terminal_status = str(event.get("status") or "completed")
                if terminal_status not in {"completed", "success", "ok"}:
                    status = "failed"
                    error_class = "agent_execution_failed"
                    error = f"pi turn ended with status {terminal_status}"
                break
        if status != "completed":
            return status, error_class, error
        stats = self._request_response({"id": f"{prompt_id}-stats", "type": "get_session_stats"})
        update = self._driver_state_update(stats.get("data") or {}, turn_id)
        return status, error_class, error, update

    def _restore_session_if_needed(self, turn_id):
        token = self.current_grant.get("driver_state") or {}
        state_digest = str(token.get("state_digest") or "")
        if not state_digest or state_digest == self.restored_state_digest:
            return
        payload = token.get("state_payload")
        if not payload:
            return
        if not isinstance(payload, dict):
            raise RuntimeError("pi restore state_payload must be an object")
        state_kind = payload.get("state_kind")
        if state_kind == "pi_uninitialized":
            self.restored_state_digest = state_digest
            return
        if state_kind != "pi_session":
            raise RuntimeError(f"unsupported pi restore state_kind {state_kind}")
        expected_rel, expected_file = normalize_pi_session_file(payload.get("selected_session_file"))
        if expected_rel != payload.get("selected_session_relpath"):
            raise RuntimeError("pi restore session relpath mismatch")
        expected_session_id = str(payload.get("selected_session_id") or "").strip()
        if not expected_session_id:
            raise RuntimeError("pi restore selected_session_id is required")
        self._request_response(
            {
                "id": f"harness-restore-{turn_id or int(time.time_ns())}",
                "type": "switch_session",
                "sessionFile": expected_file,
            }
        )
        stats = self._request_response({"id": f"harness-restore-{turn_id or int(time.time_ns())}-stats", "type": "get_session_stats"})
        relpath, selected_file = normalize_pi_session_file((stats.get("data") or {}).get("sessionFile"))
        session_id = str((stats.get("data") or {}).get("sessionId") or "").strip()
        if relpath != expected_rel or selected_file != expected_file or session_id != expected_session_id:
            raise RuntimeError("pi restore selected session verification failed")
        self.restored_state_digest = state_digest

    def _driver_state_update(self, stats, turn_id):
        token = self.current_grant.get("driver_state") or {}
        previous_digest = str(token.get("state_digest") or "")
        previous_version = int(token.get("state_version") or 0)
        if token.get("driver_id") != "pi" or not previous_digest.startswith("sha256:") or previous_version <= 0:
            raise RuntimeError("pi turn grant missing current driver_state token")
        relpath, selected_file = normalize_pi_session_file(stats.get("sessionFile"))
        session_id = str(stats.get("sessionId") or "").strip()
        if not session_id:
            raise RuntimeError("pi sessionId is required")
        state_payload = {
            "schema_version": 1,
            "driver_id": "pi",
            "state_kind": "pi_session",
            "session_dir": PI_SESSION_DIR,
            "selected_session_relpath": relpath,
            "selected_session_file": selected_file,
            "selected_session_id": session_id,
            "last_completed_turn_id": str(turn_id),
        }
        return {
            "driver_id": "pi",
            "previous_state_digest": previous_digest,
            "state_payload": state_payload,
            "state_digest": driver_state_digest(state_payload),
            "state_version": previous_version + 1,
        }

    def close(self):
        if self.proc is None:
            return
        try:
            self.proc.terminate()
        except OSError:
            pass


class NativeEventsProbeRunner:
    def run_turn(self, content, emit):
        emit(
            "stdout",
            {
                "schema": "harness_native_events_v1",
                "event": {
                    "type": "agent.message",
                    "payload": {"content": content},
                },
            },
        )
        return "completed", "", ""

    def close(self):
        pass


RUNNER_FACTORIES = {
    "claude_code": ClaudeTurnRunner,
    "pi": PiRPCTurnRunner,
    "sh": ShellTurnRunner,
    "native_events_probe": NativeEventsProbeRunner,
}


def make_turn_runner(driver_id):
    driver_id = canonical_driver_id(driver_id)
    factory = RUNNER_FACTORIES.get(driver_id)
    if factory is not None:
        return factory()
    raise RuntimeError(f"unsupported driver {driver_id}")


def sandbox_source_ip():
    try:
        output = subprocess.check_output(["ip", "-j", "addr", "show"], text=True)
        for link in json.loads(output):
            if link.get("ifname") == "lo":
                continue
            for addr in link.get("addr_info", []):
                if addr.get("family") == "inet" and addr.get("local"):
                    return addr["local"]
    except Exception:
        pass
    return "127.0.0.1"


def parse_statuses(value, default):
    if value is None or str(value).strip() == "":
        return set(default)
    statuses = set()
    for raw in str(value).split(","):
        raw = raw.strip()
        if raw:
            statuses.add(int(raw))
    return statuses


def http_status(url, method="GET", headers=None, body=None, timeout=3.0):
    request = urllib.request.Request(url, data=body, method=method, headers=headers or {})
    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            return response.status
    except urllib.error.HTTPError as err:
        return err.code


def run_network_probe(base_url, healthz_statuses, timeout):
    if not base_url:
        raise RuntimeError("ANTHROPIC_BASE_URL is required for probe")
    base_url = base_url.rstrip("/")
    healthz_status = http_status(f"{base_url}/healthz", timeout=timeout)
    if healthz_status not in healthz_statuses:
        raise RuntimeError(f"probe GET /healthz returned {healthz_status}, want one of {sorted(healthz_statuses)}")


def run_probe(args):
    driver_id = args_driver_id(args)
    client = BridgeClient(args.bridge_dir, args.session_id, args.generation_id, driver_id, args.poll_interval)
    client.heartbeat()
    client.hello(timeout=args.timeout)
    if driver_id == "claude_code":
        run_network_probe(
            args.base_url,
            parse_statuses(args.healthz_statuses, {200}),
            args.http_timeout,
        )
    client.probe_network(timeout=args.timeout)
    client.touch_bridge_heartbeat()
    client.mark_checkpoint_ready()


def run_heartbeat_loop(args):
    client = BridgeClient(args.bridge_dir, args.session_id, args.generation_id, args_driver_id(args), args.poll_interval)
    interval = max(args.interval, 0.001)
    while True:
        client.heartbeat()
        time.sleep(interval)


def start_background_heartbeat(client, interval):
    stop = threading.Event()

    def loop():
        while not stop.wait(max(interval, 0.001)):
            try:
                client.heartbeat()
            except Exception as err:
                print(f"[bridge] heartbeat failed: {err}", file=sys.stderr, flush=True)

    thread = threading.Thread(target=loop, daemon=True)
    thread.start()
    return stop


def execute_grant(client, runner, grant):
    turn_id = int(grant["turn_id"])
    run_turn = grant.get("input") or {}
    if grant.get("turn_input_schema") != "RunTurn":
        raise RuntimeError(f"unsupported turn_input_schema {grant.get('turn_input_schema')}")
    content = str(run_turn.get("content") or "")
    output_sequence = int(client.last_output_sequence_by_turn.get(turn_id, 0)) + 1
    client.clear_checkpoint_ready()
    client.ack_turn_started(turn_id, sandbox_source_ip())

    def emit(stream, line):
        nonlocal output_sequence
        payload = line if isinstance(line, dict) else {"line": line}
        client.emit_output(turn_id, output_sequence, payload, stream=stream or "stdout")
        output_sequence += 1

    try:
        if hasattr(runner, "set_turn_context"):
            runner.set_turn_context(grant)
        result = runner.run_turn(content, emit)
        driver_state_update = None
        if isinstance(result, dict):
            status = result.get("status") or "completed"
            error_class = result.get("error_class") or ""
            error = result.get("error") or ""
            driver_state_update = result.get("driver_state_update")
        else:
            status, error_class, error = result[:3]
            if len(result) > 3:
                driver_state_update = result[3]
    except Exception as err:
        status, error_class, error = "failed", "agent_execution_failed", str(err)
        driver_state_update = None
        emit("stderr", str(err))
    if status != "completed":
        driver_state_update = None
    client.last_output_sequence_by_turn[turn_id] = output_sequence - 1
    client.ack_turn_completed(
        turn_id,
        status=status or "completed",
        error_class=error_class,
        error=error,
        driver_state_update=driver_state_update,
    )
    client.mark_checkpoint_ready()


def run_claim_loop(args, runner=None):
    driver_id = args_driver_id(args)
    client = BridgeClient(args.bridge_dir, args.session_id, args.generation_id, driver_id, args.poll_interval)
    client.heartbeat()
    client.hello(timeout=args.timeout)
    if driver_id == "claude_code":
        run_network_probe(
            args.base_url,
            parse_statuses(args.healthz_statuses, {200}),
            args.http_timeout,
        )
    client.probe_network(timeout=args.timeout)
    client.mark_checkpoint_ready()
    runner = runner or make_turn_runner(driver_id)
    stop_heartbeat = start_background_heartbeat(client, args.heartbeat_interval)
    completed = 0
    empty_polls = 0
    resume_turn_id = client.leased_turn_id
    try:
        while args.max_turns <= 0 or completed < args.max_turns:
            if resume_turn_id is not None:
                grant = client.resume_turn(int(resume_turn_id), timeout=args.timeout)
                resume_turn_id = None
            else:
                grant = client.claim_next_turn(timeout=args.timeout)
            if grant is None:
                empty_polls += 1
                if args.max_empty_polls > 0 and empty_polls >= args.max_empty_polls:
                    return
                time.sleep(max(args.idle_interval, 0.001))
                continue
            empty_polls = 0
            execute_grant(client, runner, grant)
            completed += 1
    finally:
        stop_heartbeat.set()
        if hasattr(runner, "close"):
            runner.close()


def main(argv=None):
    parser = argparse.ArgumentParser()
    parser.add_argument("--bridge-dir", default=os.environ.get("HARNESS_BRIDGE_DIR", "/harness-control/bridge"))
    parser.add_argument("--session-id", default=os.environ.get("SESSION_ID"))
    parser.add_argument("--generation-id", default=os.environ.get("GENERATION_ID"))
    parser.add_argument("--driver-id", default=os.environ.get("HARNESS_DRIVER_ID", os.environ.get("HARNESS_AGENT", "claude_code")))
    parser.add_argument("--poll-interval", type=float, default=float(os.environ.get("HARNESS_BRIDGE_POLL_INTERVAL", "0.05")))
    parser.add_argument("--timeout", type=float, default=10.0)
    parser.add_argument("--base-url", default=os.environ.get("ANTHROPIC_BASE_URL", ""))
    parser.add_argument("--healthz-statuses", default=os.environ.get("HARNESS_PROBE_HEALTHZ_STATUSES", "200"))
    parser.add_argument("--http-timeout", type=float, default=float(os.environ.get("HARNESS_PROBE_HTTP_TIMEOUT", "3")))
    subcommands = parser.add_subparsers(dest="command", required=True)
    subcommands.add_parser("probe")
    heartbeat_loop = subcommands.add_parser("heartbeat-loop")
    heartbeat_loop.add_argument("--interval", type=float, default=float(os.environ.get("HARNESS_BRIDGE_HEARTBEAT_INTERVAL", "30")))
    claim_loop = subcommands.add_parser("claim-loop")
    claim_loop.add_argument("--idle-interval", type=float, default=float(os.environ.get("HARNESS_BRIDGE_IDLE_INTERVAL", "0.05")))
    claim_loop.add_argument("--heartbeat-interval", type=float, default=float(os.environ.get("HARNESS_BRIDGE_HEARTBEAT_INTERVAL", "30")))
    claim_loop.add_argument("--max-turns", type=int, default=0)
    claim_loop.add_argument("--max-empty-polls", type=int, default=0)
    args = parser.parse_args(argv)
    if not args.session_id or not args.generation_id:
        parser.error("--session-id and --generation-id are required")
    if args.command == "probe":
        run_probe(args)
    elif args.command == "heartbeat-loop":
        run_heartbeat_loop(args)
    elif args.command == "claim-loop":
        run_claim_loop(args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
