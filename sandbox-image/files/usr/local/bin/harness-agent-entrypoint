#!/bin/sh
set -eu

echo "[entrypoint] starting" >&2

CONTROL_JSON_FILE="/harness-control/session.json"
CONTROL_ENV_FILE="/harness-control/session.env"
POLL_INTERVAL="0.05"
AGENT_USER="harness"
AGENT_UID="65534"
AGENT_GID="65534"

echo "[entrypoint] waiting for control file: $CONTROL_JSON_FILE or $CONTROL_ENV_FILE" >&2
while [ ! -f "$CONTROL_JSON_FILE" ] && [ ! -f "$CONTROL_ENV_FILE" ]; do
  sleep "$POLL_INTERVAL"
done

CONTROL_FILE="$CONTROL_ENV_FILE"
CONTROL_FORMAT="env"
if [ -f "$CONTROL_JSON_FILE" ]; then
  CONTROL_FILE="$CONTROL_JSON_FILE"
  CONTROL_FORMAT="json"
fi

echo "[entrypoint] loading control file: $CONTROL_FILE" >&2
if [ "$CONTROL_FORMAT" = "json" ]; then
  # shellcheck disable=SC2016
  CONTROL_EXPORTS="$(
    python3 - "$CONTROL_FILE" <<'PY'
import hashlib
import hmac
import json
import shlex
import sys

with open(sys.argv[1], "r", encoding="utf-8") as f:
    raw = json.load(f)

if not isinstance(raw, dict) or "payload" not in raw or "digest" not in raw:
    raise SystemExit("control manifest must be {payload,digest}")

payload = raw["payload"]
digest = raw["digest"]
computed = hashlib.sha256(
    json.dumps(payload, sort_keys=True, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
).hexdigest()
if not hmac.compare_digest(computed, str(digest)):
    raise SystemExit("control manifest digest mismatch")

data = payload

def emit(key, value):
    if value is None or value == "":
        return
    if isinstance(value, bool):
        value = "1" if value else "0"
    print(f"export {key}={shlex.quote(str(value))}")

emit("SESSION_ID", data.get("session_id"))
emit("GENERATION_ID", data.get("generation_id"))
emit("NETWORK_PROFILE_ID", data.get("network_profile_id"))
emit("AGENT_RUNTIME_PROFILE_ID", data.get("agent_runtime_profile_id"))
emit("MANIFEST_VERSION", data.get("manifest_version"))
emit("SESSION_WORKSPACE", data.get("workspace_path"))
emit("HARNESS_AGENT_HOME", data.get("agent_home_path"))
emit("HARNESS_AGENT", data.get("agent"))
emit("CLAUDE_SESSION_UUID", data.get("claude_session_uuid"))
emit("CLAUDE_RESUME", data.get("resume_claude", False))
emit("CLAUDE_MODEL", data.get("model", "sonnet"))
emit("CLAUDE_OUTPUT_FORMAT", data.get("output_format", "stream-json"))
emit("CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC", data.get("claude_code_disable_nonessential_traffic", True))
emit("ANTHROPIC_BASE_URL", data.get("anthropic_base_url"))
emit("ANTHROPIC_API_KEY_SECRET_ID", data.get("anthropic_api_key_secret_id"))
emit("ANTHROPIC_AUTH_TOKEN_SECRET_ID", data.get("anthropic_auth_token_secret_id"))
emit("SECRET_VERSION", data.get("secret_version"))
emit("SECRET_MOUNT_PATH", data.get("secret_mount_path"))
PY
  )" || exit 65
  eval "$CONTROL_EXPORTS"
else
  # shellcheck disable=SC1090
  . "$CONTROL_FILE"
fi

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export PATH

[ -n "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-}" ] && export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC

: "${SESSION_ID:?SESSION_ID is required in control file}"

check_expected() {
  actual="$1"
  expected="$2"
  label="$3"
  if [ -n "$expected" ] && [ "$actual" != "$expected" ]; then
    echo "[entrypoint] ${label} mismatch" >&2
    exit 65
  fi
}

check_expected "$SESSION_ID" "${HARNESS_EXPECTED_SESSION_ID:-}" "session_id"
check_expected "${GENERATION_ID:-}" "${HARNESS_EXPECTED_GENERATION_ID:-}" "generation_id"
check_expected "${NETWORK_PROFILE_ID:-}" "${HARNESS_EXPECTED_NETWORK_PROFILE_ID:-}" "network_profile_id"
check_expected "${AGENT_RUNTIME_PROFILE_ID:-}" "${HARNESS_EXPECTED_AGENT_RUNTIME_PROFILE_ID:-}" "agent_runtime_profile_id"
check_expected "${MANIFEST_VERSION:-}" "${HARNESS_EXPECTED_MANIFEST_VERSION:-}" "manifest_version"
check_expected "${ANTHROPIC_API_KEY_SECRET_ID:-}" "${HARNESS_EXPECTED_API_KEY_SECRET_ID:-}" "anthropic_api_key_secret_id"
check_expected "${ANTHROPIC_AUTH_TOKEN_SECRET_ID:-}" "${HARNESS_EXPECTED_AUTH_TOKEN_SECRET_ID:-}" "anthropic_auth_token_secret_id"
check_expected "${SECRET_VERSION:-}" "${HARNESS_EXPECTED_SECRET_VERSION:-}" "secret_version"

if [ "${HARNESS_AGENT:-claude}" = "claude" ]; then
  : "${ANTHROPIC_BASE_URL:?ANTHROPIC_BASE_URL is required for claude agent}"
  : "${SECRET_MOUNT_PATH:?SECRET_MOUNT_PATH is required for claude agent}"
  : "${ANTHROPIC_API_KEY_SECRET_ID:?ANTHROPIC_API_KEY_SECRET_ID is required for claude agent}"
  : "${ANTHROPIC_AUTH_TOKEN_SECRET_ID:?ANTHROPIC_AUTH_TOKEN_SECRET_ID is required for claude agent}"
  : "${SECRET_VERSION:?SECRET_VERSION is required for claude agent}"
  : "${HARNESS_SECRET_READERS_GID:?HARNESS_SECRET_READERS_GID is required for claude agent}"
  export ANTHROPIC_BASE_URL SECRET_MOUNT_PATH ANTHROPIC_API_KEY_SECRET_ID ANTHROPIC_AUTH_TOKEN_SECRET_ID SECRET_VERSION
fi

if [ "${HARNESS_BRIDGE_MODE:-}" = "probe" ]; then
  echo "[entrypoint] bridge probe starting" >&2
  exec /usr/local/bin/harness-bridge-client probe
fi
if [ "${HARNESS_BRIDGE_MODE:-auto}" = "auto" ]; then
  echo "[entrypoint] bridge probe starting" >&2
  /usr/local/bin/harness-bridge-client probe
fi

SESSION_WORKSPACE="${SESSION_WORKSPACE:-/sessions/$SESSION_ID}"
mkdir -p "$SESSION_WORKSPACE"

# Keep the agent's writable HOME outside /workspace so Claude internals do not
# appear in the user-visible file tree or artifact list.
AGENT_HOME="${HARNESS_AGENT_HOME:-/agent-homes/$SESSION_ID}"

ensure_agent_user() {
  mkdir -p "$AGENT_HOME"
  chown -R "$AGENT_UID:$AGENT_GID" "$AGENT_HOME" "$SESSION_WORKSPACE" 2>/dev/null || true
}

if [ -d /workspace ] && [ ! -L /workspace ]; then
  rmdir /workspace 2>/dev/null || true
fi
ln -sfn "$SESSION_WORKSPACE" /workspace

cd /workspace

echo "[entrypoint] agent: ${HARNESS_AGENT:-claude}" >&2
case "${HARNESS_AGENT:-claude}" in
  claude)
    echo "[entrypoint] claude turn loop starting" >&2
    : "${CLAUDE_SESSION_UUID:?CLAUDE_SESSION_UUID is required for claude agent}"
    ensure_agent_user

    first_turn=1
    while IFS= read -r turn; do
      [ -n "$turn" ] || continue
      echo "[entrypoint] claude turn starting" >&2
      set -- /usr/local/bin/claude \
        --bare \
        --permission-mode bypassPermissions \
        -p \
        --model "${CLAUDE_MODEL:-sonnet}" \
        --input-format stream-json \
        --output-format "${CLAUDE_OUTPUT_FORMAT:-stream-json}" \
        --include-partial-messages \
        --replay-user-messages \
        --verbose
      if [ "$first_turn" = "1" ] && [ "${CLAUDE_RESUME:-0}" != "1" ]; then
        set -- "$@" --session-id "$CLAUDE_SESSION_UUID"
      else
        set -- "$@" --resume "$CLAUDE_SESSION_UUID"
      fi
      set +e
      printf '%s\n' "$turn" | setpriv --reuid "$AGENT_UID" --regid "$AGENT_GID" --groups "$HARNESS_SECRET_READERS_GID" \
        env HOME="$AGENT_HOME" USER="$AGENT_USER" LOGNAME="$AGENT_USER" \
        ANTHROPIC_BASE_URL="$ANTHROPIC_BASE_URL" \
        SECRET_MOUNT_PATH="$SECRET_MOUNT_PATH" \
        ANTHROPIC_API_KEY_SECRET_ID="$ANTHROPIC_API_KEY_SECRET_ID" \
        ANTHROPIC_AUTH_TOKEN_SECRET_ID="$ANTHROPIC_AUTH_TOKEN_SECRET_ID" \
        SECRET_VERSION="$SECRET_VERSION" \
        sh -c '
          ANTHROPIC_API_KEY="$(cat "$SECRET_MOUNT_PATH/$ANTHROPIC_API_KEY_SECRET_ID/$SECRET_VERSION")"
          ANTHROPIC_AUTH_TOKEN="$(cat "$SECRET_MOUNT_PATH/$ANTHROPIC_AUTH_TOKEN_SECRET_ID/$SECRET_VERSION")"
          export ANTHROPIC_BASE_URL ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
          exec "$@"
        ' sh "$@"
      status=$?
      set -e
      if [ "$status" -ne 0 ]; then
        echo "[entrypoint] claude turn exited with status $status" >&2
      fi
      first_turn=0
    done
    echo "[entrypoint] stdin closed; exiting" >&2
    ;;
  sh)
    echo "[entrypoint] sh agent starting" >&2
    exec /usr/local/bin/harness-shell-agent
    ;;
  *)
    echo "unknown HARNESS_AGENT: ${HARNESS_AGENT}" >&2
    exit 64
    ;;
esac
