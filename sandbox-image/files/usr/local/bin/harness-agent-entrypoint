#!/bin/sh
set -eu

echo "[entrypoint] starting" >&2

CONTROL_JSON_FILE="/harness-control/session.json"
POLL_INTERVAL="0.05"
AGENT_USER="harness"
AGENT_UID="${HARNESS_AGENT_UID:-}"
AGENT_GID="${HARNESS_AGENT_GID:-}"
[ -n "$AGENT_UID" ] || { echo "[entrypoint] HARNESS_AGENT_UID is required" >&2; exit 65; }
[ -n "$AGENT_GID" ] || { echo "[entrypoint] HARNESS_AGENT_GID is required" >&2; exit 65; }
export HARNESS_AGENT_UID="$AGENT_UID"
export HARNESS_AGENT_GID="$AGENT_GID"

echo "[entrypoint] waiting for control file: $CONTROL_JSON_FILE" >&2
while [ ! -f "$CONTROL_JSON_FILE" ]; do
  sleep "$POLL_INTERVAL"
done

CONTROL_FILE="$CONTROL_JSON_FILE"

echo "[entrypoint] loading control file: $CONTROL_FILE" >&2
# shellcheck disable=SC2016
CONTROL_EXPORTS="$(
  python3 - "$CONTROL_FILE" <<'PY'
import shlex
import sys

sys.path.insert(0, "/usr/local/lib")
from harness_manifest import load_control_manifest

data = load_control_manifest(sys.argv[1])
driver_runtime = data.get("driver_runtime")
if not isinstance(driver_runtime, dict):
    driver_runtime = {}

def driver_runtime_value(key):
    return driver_runtime.get(key)

def emit(key, value):
    if value is None or value == "":
        return
    if isinstance(value, bool):
        value = "1" if value else "0"
    print(f"export {key}={shlex.quote(str(value))}")

emit("SESSION_ID", data.get("session_id"))
emit("GENERATION_ID", data.get("generation_id"))
emit("NETWORK_PROFILE_ID", data.get("network_profile_id"))
emit("AGENT_RUNTIME_PROFILE_ID", data.get("agent_runtime_profile_id"))
emit("MANIFEST_VERSION", data.get("manifest_version"))
emit("SESSION_WORKSPACE", data.get("workspace_path"))
emit("HARNESS_AGENT_HOME", data.get("agent_home_path"))
emit("HARNESS_DRIVER_ID", data.get("driver_id"))
emit("HARNESS_BRIDGE_PROTOCOL_VERSION", data.get("bridge_protocol_version"))
emit("HARNESS_TURN_INPUT_SCHEMA", data.get("turn_input_schema"))
emit("CLAUDE_MODEL", data.get("model", "sonnet"))
emit("CLAUDE_OUTPUT_FORMAT", data.get("output_format", "stream-json"))
emit("CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC", driver_runtime_value("claude_code_disable_nonessential_traffic"))
emit("ANTHROPIC_BASE_URL", data.get("sandbox_model_proxy_base_url"))
emit("PI_CODING_AGENT_DIR", driver_runtime_value("pi_coding_agent_dir"))
emit("PI_CODING_AGENT_SESSION_DIR", driver_runtime_value("pi_coding_agent_session_dir"))
emit("PI_OFFLINE", driver_runtime_value("pi_offline"))
emit("PI_SKIP_VERSION_CHECK", driver_runtime_value("pi_skip_version_check"))
pi_telemetry_disabled = driver_runtime_value("pi_telemetry_disabled")
if pi_telemetry_disabled is not None:
    emit("PI_TELEMETRY", "0" if pi_telemetry_disabled else "1")
PY
)" || exit 65
eval "$CONTROL_EXPORTS"

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export PATH

[ -n "${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-}" ] && export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC

: "${SESSION_ID:?SESSION_ID is required in control file}"
: "${HARNESS_DRIVER_ID:?HARNESS_DRIVER_ID is required in control file}"

check_expected() {
  actual="$1"
  expected="$2"
  label="$3"
  if [ -n "$expected" ] && [ "$actual" != "$expected" ]; then
    echo "[entrypoint] expected ${label}=${expected} got ${actual}" >&2
    exit 65
  fi
}

check_expected "$SESSION_ID" "${HARNESS_EXPECTED_SESSION_ID:-}" "session_id"
check_expected "${GENERATION_ID:-}" "${HARNESS_EXPECTED_GENERATION_ID:-}" "generation_id"
check_expected "${NETWORK_PROFILE_ID:-}" "${HARNESS_EXPECTED_NETWORK_PROFILE_ID:-}" "network_profile_id"
check_expected "${AGENT_RUNTIME_PROFILE_ID:-}" "${HARNESS_EXPECTED_AGENT_RUNTIME_PROFILE_ID:-}" "agent_runtime_profile_id"
check_expected "${MANIFEST_VERSION:-}" "${HARNESS_EXPECTED_MANIFEST_VERSION:-}" "manifest_version"

if [ -n "${SECRET_MOUNT_PATH:-}" ] || [ -n "${ANTHROPIC_API_KEY_SECRET_ID:-}" ] || [ -n "${ANTHROPIC_AUTH_TOKEN_SECRET_ID:-}" ] || [ -n "${SECRET_VERSION:-}" ] || [ -n "${HARNESS_SECRET_READERS_GID:-}" ]; then
  echo "[entrypoint] sandbox secret mounts are not supported" >&2
  exit 65
fi
unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN

if [ "$HARNESS_DRIVER_ID" = "claude_code" ]; then
  : "${ANTHROPIC_BASE_URL:?ANTHROPIC_BASE_URL is required for claude_code driver}"
  export ANTHROPIC_BASE_URL
fi

if [ "${HARNESS_BRIDGE_MODE:-}" = "probe" ]; then
  echo "[entrypoint] bridge probe starting" >&2
  exec /usr/local/bin/harness-bridge-client probe
fi

# Keep the agent's writable HOME outside /workspace so Claude internals do not
# appear in the user-visible file tree or artifact list.
: "${SESSION_WORKSPACE:?SESSION_WORKSPACE is required in control file}"
: "${HARNESS_AGENT_HOME:?HARNESS_AGENT_HOME is required in control file}"
AGENT_HOME="$HARNESS_AGENT_HOME"

ensure_agent_user() {
  chown -R "$AGENT_UID:$AGENT_GID" "$AGENT_HOME" "$SESSION_WORKSPACE" 2>/dev/null || true
}

if [ "$SESSION_WORKSPACE" != "/workspace" ]; then
  echo "[entrypoint] SESSION_WORKSPACE must be /workspace" >&2
  exit 65
fi
[ -d /workspace ] || { echo "[entrypoint] /workspace mount is required" >&2; exit 65; }

if [ "$AGENT_HOME" != "/agent-home" ]; then
  echo "[entrypoint] HARNESS_AGENT_HOME must be /agent-home" >&2
  exit 65
fi
[ -d /agent-home ] || { echo "[entrypoint] /agent-home mount is required" >&2; exit 65; }

cd /workspace

if [ "$HARNESS_DRIVER_ID" = "claude_code" ]; then
  ensure_agent_user
fi

exec_bridge_client() {
  if [ "$HARNESS_DRIVER_ID" = "claude_code" ]; then
    if [ "$(id -u)" = "$AGENT_UID" ] && [ "$(id -g)" = "$AGENT_GID" ]; then
      exec env HOME="$AGENT_HOME" USER="$AGENT_USER" LOGNAME="$AGENT_USER" \
        HARNESS_AGENT_HOME="$AGENT_HOME" \
        HARNESS_DRIVER_ID="$HARNESS_DRIVER_ID" \
        ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-}" \
        /usr/local/bin/harness-bridge-client "$@"
    fi
    exec setpriv --reuid "$AGENT_UID" --regid "$AGENT_GID" --clear-groups \
      env HOME="$AGENT_HOME" USER="$AGENT_USER" LOGNAME="$AGENT_USER" \
      HARNESS_AGENT_HOME="$AGENT_HOME" \
      HARNESS_DRIVER_ID="$HARNESS_DRIVER_ID" \
      ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-}" \
      /usr/local/bin/harness-bridge-client "$@"
  fi
  exec /usr/local/bin/harness-bridge-client "$@"
}

if [ "${HARNESS_BRIDGE_MODE:-}" = "claim-loop" ]; then
  echo "[entrypoint] bridge claim loop starting" >&2
  exec_bridge_client claim-loop
fi
if [ "${HARNESS_BRIDGE_MODE:-}" = "heartbeat-loop" ]; then
  echo "[entrypoint] bridge heartbeat loop starting" >&2
  exec_bridge_client heartbeat-loop
fi

echo "[entrypoint] unsupported HARNESS_BRIDGE_MODE: ${HARNESS_BRIDGE_MODE:-}" >&2
exit 64
